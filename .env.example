# Redis (BullMQ)
REDIS_URL=redis://default:xxx@your-redis-host:6379

# Cloudflare R2 / S3
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=your-bucket
R2_PUBLIC_URL=https://your-r2-public-domain.com

# Supabase (server-side — service role)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxx

# Supabase (browser-side — anon key, for Realtime subscriptions)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx

# Modal GPU Transcriber
MODAL_TRANSCRIBER_URL=https://your-workspace--pianist-v3-transcriber-transcribe.modal.run
